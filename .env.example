# ===== SUPABASE (חינם - supabase.com) =====
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===== STRIPE PAYMENTS (חינם - stripe.com) =====
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ===== RESEND EMAIL (חינם - resend.com) =====
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@bamali.co.il

# ===== APP CONFIG =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=במה לי

# ===== COMMISSION RATES =====
PLATFORM_FEE_ORGANIZER=0.05  # 5% from organizer
PLATFORM_FEE_VENUE=0.07       # 7% from venue owner
